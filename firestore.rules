rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@ancedu.com' ||
        request.auth.token.email == 'i.am.jerom.allan@gmail.com'
      );
    }

    match /registrations/{registrationId} {
      // Allow anyone to create a registration (public form)
      allow create: if true;

      // Only authenticated admins can read/list registrations
      allow read: if isAdmin();

      // Admins can update and delete registrations
      allow update, delete: if isAdmin();
    }
  }
}
