{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "A registration for the UWL Alumni Networking event.",
      "type": "object",
      "properties": {
        "studentName": {
          "type": "string",
          "description": "The full name of the student."
        },
        "contactNumber": {
          "type": "string",
          "description": "The contact number of the student."
        },
        "program": {
          "type": "string",
          "description": "The program the student is enrolled in.",
          "enum": ["MBA", "Top Up", "MSc", "LLM", "L7"]
        },
        "uwlIdNo": {
          "type": "string",
          "description": "The UWL ID number of the student."
        },
        "informAdvance": {
          "type": "boolean",
          "description": "Agreement to inform in advance if unable to attend."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the registration was created."
        }
      },
      "required": [
        "studentName",
        "contactNumber",
        "program",
        "uwlIdNo",
        "informAdvance",
        "createdAt"
      ]
    },
    "EventSettings": {
      "title": "Event Settings",
      "description": "Configuration for the event details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "terms": { "type": "string" }
      },
      "required": ["title", "subtitle", "date", "location", "terms"]
    }
  },
  "firestore": {
    "registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Collection of event registrations."
    },
    "settings/{settingId}": {
      "schema": "EventSettings",
      "description": "Global settings for the event."
    }
  }
}
